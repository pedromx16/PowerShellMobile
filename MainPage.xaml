<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PowerShellMobile.MainPage"
             BackgroundColor="Black">

    <VerticalStackLayout Padding="10" Spacing="5">

        <Label Text="PowerShell Console"
               FontSize="20"
               TextColor="White"
               HorizontalOptions="Center" />

        <!-- Linha de comando ocupando toda a largura -->
        <Grid ColumnDefinitions="*,Auto">
            <Entry x:Name="CommandEntry"
                   Placeholder="Digite um comando PowerShell..."
                   TextColor="White"
                   BackgroundColor="Black"
                   Grid.Column="0"
                   HorizontalOptions="FillAndExpand" />

            <Button Text="Executar"
                    Clicked="OnExecuteClicked"
                    BackgroundColor="Purple"
                    TextColor="White"
                    Grid.Column="1"
                    HorizontalOptions="End"
                    WidthRequest="120" />
        </Grid>

        <!-- Saída com rolagem -->
        <ScrollView VerticalOptions="FillAndExpand"
            	    HorizontalOptions="FillAndExpand">
    	    <Editor x:Name="OutputEditor"
                    TextColor="White"
                    BackgroundColor="Black"
                    IsReadOnly="True"
                    FontFamily="Consolas"
                    HorizontalOptions="FillAndExpand"
                    VerticalOptions="FillAndExpand"
                    HeightRequest="400" />
        </ScrollView>

    </VerticalStackLayout>
</ContentPage>


